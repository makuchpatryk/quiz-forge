{
  "extends": "../../tsconfig.base.json",
  "emitDecoratorMetadata": true,
  "experimentalDecorators": true,
  "compilerOptions": {
    "strictPropertyInitialization": false,
    "outDir": "./dist",
    "baseUrl": "./",
    "target": "ES2021",
    "module": "commonjs",
    "strict": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "incremental": true
  }
}
