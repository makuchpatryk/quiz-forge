# ===========================================
# Random Quiz Generator — Environment Variables
# ===========================================
# Copy this file to apps/backend/.env and fill in your values.
# Default values below match the docker-compose.yaml dev setup.

# -------------------------------------------
# App
# -------------------------------------------
PORT=3001
APP_SECRET=change-me-to-a-random-string

# -------------------------------------------
# Database (PostgreSQL)
# -------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=quizdb

# -------------------------------------------
# JWT
# -------------------------------------------
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret

# -------------------------------------------
# Frontend (Nuxt runtime config)
# -------------------------------------------
API_BASE_URL=http://localhost:3001

